# 智企通 MVP — 后端环境变量配置示例
# 复制本文件为 .env 并填入真实 API key

# LLM 运行模式：mock（返回预设数据） / real（调用真实 LLM）
LLM_MODE=real

# Step 1 企业画像 + Step 4 服务匹配 — GLM-5.1
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# Step 5 ESG 分析 — Kimi K2.6
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1

# 前端 CORS 白名单（本地开发默认已包含，通常无需修改）
# CORS_ORIGINS=["http://localhost:5173","http://localhost:5174"]
